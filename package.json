{
  "name": "typescript-boilerplate",
  "version": "1.4.1",
  "main": "src/main.ts",
  "scripts": {
    "start": "npx tsx ./src/main.ts",
    "lint": "cross-env TIMING=1 npx eslint",
    "lint:fix": "npm run lint -- --fix",
    "lint:debug": "npm run lint -- --debug",
    "build": "tsup && mv ./dist/main.js ./function-out.js",
    "format:md": "npx prettier --write \"**/*.md\"",
    "typecheck": "npx tsc --noEmit",
    "test": "npx vitest",
    "test:run": "npx vitest run",
    "test:coverage": "npx vitest run --coverage",
    "bump-version": "npx tsx ./scripts/bump-version.script.ts && npm audit fix",
    "parse-llm-response": "npx tsx ./scripts/split-plain-code.wrap.ts",
    "after-parse-llm-response": "npx tsx ./scripts/create-auto-ts-paths.script.ts && npm run lint:fix && npm run format:md",
    "format": "npx prettier . --write",
    "postinstall": "./scripts/link-codex-skills.sh"
  },
  "keywords": [
    "typescript",
    "boilerplate",
    "eslint",
    "prettier",
    "modern",
    "vitest",
    "template"
  ],
  "author": "Dmytro Vakulenko",
  "license": "ISC",
  "description": "Modern, scalable TypeScript boilerplate for Node.js projects with strict linting, Prettier formatting, modular structure, and Vitest testing.",
  "dependencies": {
    "uuid": "^13.0.0",
    "typed-dotenv": "^10.0.2"
  },
  "devDependencies": {
    "@darraghor/eslint-plugin-nestjs-typed": "^7.1.26",
    "@dword-design/eslint-plugin-import-alias": "^8.1.7",
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^24.12.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/eslint-plugin": "^1.6.10",
    "cross-env": "^10.1.0",
    "deepmerge": "^4.3.1",
    "eslint": "^10.0.3",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-naming": "^1.9.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-no-barrel-files": "^1.2.2",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "json5": "^2.2.3",
    "prettier": "^3.8.1",
    "type-fest": "^5.4.4",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "unplugin-swc": "^1.5.9",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "eslint-config-airbnb-base": {
      "eslint": "^10"
    },
    "eslint-plugin-import": {
      "eslint": "^10"
    }
  },
  "directories": {
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git@github-personal:DrSmile444/typescript-boilerplate.git"
  }
}
